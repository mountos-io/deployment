# ============================================================================
# mountOS init-hub (production) — THE ASK
# ----------------------------------------------------------------------------
# Copy to answers.env and edit. Only what cannot be generated or derived.
#   GENERATED (by `make bootstrap`): per-service Ed25519 keypairs, dashboard
#     HMAC, admin keypair, AppRole (hashicorp store only). You keep
#     admin_private. api-master is generated separately, per region, by
#     `make region-bootstrap`.
#   DERIVED: ports (appserv HTTP + SRPC 9443), advertise IP (IMDS), the hub
#     region + uno cluster id, the admin schema.
# This is a CLIENT package: no dev-loop scaffolding, no shipped secrets, no destroy targets.
# ============================================================================

# -- target & topology --
MODE=production                 # production (HA defaults) | non-production
CLOUD=aws
AWS_REGION=us-east-1
AZS=3                           # production: 3 (appserv spread + future regions)
HUB_DOMAIN=                     # REQUIRED, no default — your hub's real public FQDN (e.g. hub.acme.com); used for Route53 + ALB ACM

# -- resource namespace prefix --
# Optional, empty by default. Set when this cloud account/project/subscription
# already hosts another mountOS deployment, so secret names and provisioned
# resource names don't collide (they all root on "mountos" otherwise). 1-11
# lowercase alphanumeric/hyphen characters. Must equal the Terraform
# resource_prefix variable used for the same deployment (`make bootstrap` /
# `make region-bootstrap` read this value; Terraform reads its own tfvars copy).
RESOURCE_PREFIX=

# -- secret store --
# This package NEVER installs or launches HashiCorp Vault (license posture:
# we only write initial values into a store you own or the cloud provides).
#   aws (RECOMMENDED on AWS)  cloud-native Secrets Manager: platform-managed
#                             HA, instance-role auth, `make bootstrap` seeds it
#                             with your ambient aws CLI credentials.
#   hashicorp                 byo Vault (HCP Vault Dedicated or your own
#                             cluster): give us the https address + a
#                             short-lived bootstrap token; we seed values only.
#   gcp | azure               the other clouds' native stores (use with CLOUD=gcp|azure).
VAULT_PROVIDER=aws
# hashicorp only (all optional otherwise — keep unused lines commented so a
# sourced answers.env cannot clobber values exported in your shell):
#VAULT_ADDR=                    # your byo Vault https address (also export VAULT_TOKEN)
# private CA: keep the CA PEM in a file and paste it into tfvars vault_ca_pem;
# export VAULT_CACERT=<path> when running make bootstrap/region-bootstrap/verify.
# gcp: VAULT_GCP_PROJECT_ID=<project>
# azure: VAULT_AZURE_URL=`terraform output hub_key_vault_url`
#        (region-bootstrap also: REGION_VAULT_AZURE_URL=`terraform output region_key_vault_url`)

# -- admin database (PostgreSQL dialect preferred) --
# RECOMMENDED: byo — bring a managed HA PostgreSQL you already operate
# (Aurora, RDS Multi-AZ, etc.). The DSN below is read ONLY by `make bootstrap`
# to seed the secret store; it is never a Terraform value, never in tfstate.
ADMIN_DB_MODE=byo               # byo | provision-rds
ADMIN_DB_DIALECT=postgresql     # postgresql | mysql
ADMIN_DB_PROVIDER_VERSION=18    # engine major version (byo: your server's)
ADMIN_DB_URL=                   # byo: your DSN incl. sslmode=verify-full (preferred) or sslmode=require — the seed fails closed otherwise
#ADMIN_DB_PROVIDER=             # optional byo refinement: aurora-postgresql | alloydb | cockroachdb | ... (default: the dialect)
# provisioned mode (leave ADMIN_DB_URL empty): host + ONE password reference,
# all from `terraform output`; the seed fetches the password + builds the DSN.
# Master username defaults to `mountos` — if you changed db_username /
# region_db_username in tfvars, also export ADMIN_DB_USERNAME / REGION_DB_USERNAME.
#ADMIN_DB_HOST=                 # `terraform output admin_db_host`
#ADMIN_DB_SECRET_ARN=           # AWS:   `terraform output admin_db_secret_arn` (AWS-managed master password)
#ADMIN_DB_PASSWORD_SECRET=      # GCP:   `terraform output admin_db_password_secret`
#ADMIN_DB_SECRET_ID=            # Azure: `terraform output admin_db_secret_id`

# -- region database + secret store (read by `make region-bootstrap`) --
# Same byo-first guidance as above. All optional — they can also be exported
# in the region-bootstrap environment directly (kept commented here so the
# sourced answers.env cannot clobber exported values with empty strings).
#REGION_VAULT_PROVIDER=         # default: VAULT_PROVIDER. hashicorp: also export REGION_VAULT_ADDR + REGION_VAULT_TOKEN (+ HUB_VAULT_ADDR/HUB_VAULT_TOKEN)
#REGION_DB_URL=                 # byo: mountos_data DSN incl. sslmode=verify-full or sslmode=require
#REGION_DB_DIALECT=             # default: ADMIN_DB_DIALECT
#REGION_DB_PROVIDER=            # default: REGION_DB_DIALECT
#REGION_DB_PROVIDER_VERSION=    # default: ADMIN_DB_PROVIDER_VERSION
# provisioned mode (leave REGION_DB_URL empty): host + ONE password reference.
#REGION_DB_HOST=                # `terraform output region_db_host`
#REGION_DB_SECRET_ARN=          # AWS:   `terraform output region_db_secret_arn`
#REGION_DB_PASSWORD_SECRET=     # GCP:   `terraform output region_db_password_secret`
#REGION_DB_SECRET_ID=           # Azure: `terraform output region_db_secret_id`

# -- HUB (appserv) --
APPSERV_COUNT=2                 # behind ALB + NLB
APPSERV_INSTANCE_TYPE=m7g.large # Graviton/arm64 control-plane
HUB_TLS=alb-reencrypt-nlb       # ALB(HTTPS:443, ACM) re-encrypt to self-signed + NLB(TCP:9443) SRPC

# -- binary + license --
MOS_VERSION=                    # appserv package version from https://n.sh (empty = latest)
# LICENSE: none required. With no license you get the built-in free 5 TiB default.
# Raise capacity by loading a vendor license post-deploy via the admin client / SDK.
