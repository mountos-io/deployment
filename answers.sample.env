# ============================================================================
# mountOS init-hub (production) — THE ASK
# ----------------------------------------------------------------------------
# Copy to answers.env and edit. Only what cannot be generated or derived.
#   GENERATED (by `make bootstrap`): per-service Ed25519 keypairs, dashboard
#     HMAC, admin keypair, api-master, Vault AppRole. You keep admin_private.
#   DERIVED: ports (appserv HTTP + SRPC 9443), advertise IP (IMDS), the hub
#     region + uno cluster id, the admin schema.
# This is a CLIENT package: no dev-loop scaffolding, no shipped secrets, no destroy targets.
# ============================================================================

# -- target & topology --
MODE=production                 # production (HA) | eval
CLOUD=aws
AWS_REGION=us-east-1
AZS=3                           # production: 3 (appserv spread + future regions)
HUB_DOMAIN=                     # REQUIRED, no default — your hub's real public FQDN (e.g. hub.acme.com); used for Route53 + ALB ACM

# -- vault (provider x hosting) --
VAULT_PROVIDER=hashicorp        # hashicorp | aws-sm
VAULT_HOSTING=self-hosted       # self-hosted (Terraform provisions Vault + KMS auto-unseal)
                                #   | managed-byo (HCP / SM: you bring the address)
VAULT_ADDR=                     # filled from `terraform output` (self-hosted) or your managed addr

# -- admin database --
ADMIN_DB_MODE=provision-rds     # provision-rds | byo
ADMIN_DB_DIALECT=postgresql     # postgresql | mysql
ADMIN_DB_PROVIDER_VERSION=18    # PostgreSQL 18 (current latest)
ADMIN_DB_URL=                   # filled from `terraform output` (provision-rds) or your BYO DSN

# -- HUB (appserv) --
APPSERV_COUNT=2                 # behind ALB + NLB
APPSERV_INSTANCE_TYPE=m7g.large # Graviton/arm64 control-plane
HUB_TLS=alb-reencrypt-nlb       # ALB(HTTPS:443, ACM) re-encrypt to self-signed + NLB(TCP:9443) SRPC

# -- binary + license --
MOS_VERSION=                    # appserv package version from https://n.sh (empty = latest)
# LICENSE: none required. With no license you get the built-in free 5 TiB default.
# Raise capacity by loading a vendor license post-deploy via the admin client / SDK.
