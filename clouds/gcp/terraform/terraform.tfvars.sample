# Copy to terraform.tfvars and fill in. Production placeholders below.

project_id = "" # REQUIRED — your GCP project id
region     = "us-central1"
mode       = "production"

# Set only if this GCP project already hosts another mountOS deployment; must match VAULT_RESOURCE_PREFIX on every service.
resource_prefix = ""

# Public hub. Clients reach https://<hub_domain>; region services reach the
# internal LB directly (no DNS needed for SRPC).
hub_domain = "" # REQUIRED — your real public FQDN, e.g. hub.acme.com (placeholders are rejected)

# Existing Cloud DNS managed zone name for hub_domain. Empty skips DNS + the
# Google-managed cert (operator then attaches hub_certificate_id manually).
dns_zone_name = ""

hub_certificate_id = "" # set this OR dns_zone_name for the HTTPS proxy

# CIDR allowed to reach client-facing ports. Required; scope to your network — do not use 0.0.0.0/0 in production.
client_cidr = "203.0.113.0/24" # REPLACE with your operator/client CIDR

# Break-glass SSH via IAP TCP forwarding (source restricted to Google's fixed
# 35.235.240.0/20 range). Off by default — no SSH path exists at all unless
# you opt in. Also needs roles/iap.tunnelResourceAccessor + roles/compute.osLogin
# granted to the operator IAM principal (instances already have OS Login enabled).
# iap_ssh_enable = true

# appserv fleet (arm64, Tau T2A).
appserv_count         = 2
appserv_machine_type  = "t2a-standard-2"

# Admin DB (PostgreSQL dialect). RECOMMENDED: byo — bring a managed HA
# PostgreSQL you already operate (Cloud SQL HA, AlloyDB, etc.); this package
# then provisions no DB and never holds your DSN (set ADMIN_DB_URL in
# answers.env for `make bootstrap`; it is not a Terraform variable, so it
# never lands in tfstate). provision-sql is the eval/simple alternative: a
# regional Cloud SQL Postgres whose password is a Terraform value
# (random_password, stored in Secret Manager — see rds.tf's PARITY GAP note).
admin_db_mode             = "byo"
admin_db_provider_version = "POSTGRES_18" # byo: your server's major version

# provision-sql mode only:
db_tier     = "db-custom-2-8192"
db_disk_gb  = 100
db_username = "mountos"
# No db_password var. Build ADMIN_DB_URL for `make bootstrap` from
# `terraform output admin_db_host` + the admin_db_password_secret secret
# (`gcloud secrets versions access latest --secret=mountos-admin-db-password`).

# Secret store. This package NEVER installs or launches HashiCorp Vault.
#   gcp (RECOMMENDED)  cloud-native Secret Manager: platform-managed HA,
#                      instance service-account auth, `make bootstrap` seeds mountos__*.
#   hashicorp          byo Vault (HCP Vault Dedicated or your own cluster):
#                      set vault_addr; `make bootstrap` seeds it via the API.
vault_provider = "gcp"
vault_addr     = "" # hashicorp only: https address of your byo Vault
# hashicorp with a PRIVATE CA only: its CA PEM (published to Secret Manager
# for instance trust). Leave empty for a publicly-trusted certificate (HCP) —
# system CAs.
vault_ca_pem = ""

# hashicorp only: appserv AppRole from `make bootstrap`. secret_id is
# short-TTL; prefer Secret Manager/wrapped delivery.
vault_role_id   = ""
vault_secret_id = ""

# mountOS package version. Empty installs latest.
mos_version = ""

# sha256 of the https://n.sh installer script; when set, cloud-init verifies
# the download before executing it. Strongly recommended for production.
mos_installer_sha256 = ""

# Email for Cloud Monitoring alert notifications. Empty disables the channel.
alarm_email = ""

# ---------- region (dataserv + co-located gcserv) ----------

# Cluster UUID this region belongs to. Comes from the HUB provision step
# (created via the Admin SDK after the hub is up). Not created here.
region_cluster_id = "00000000-0000-0000-0000-000000000000"

# VPC placement for region resources. shared (default): region lives in the
# hub's network — simplest, no extra networking. dedicated: the region gets
# its own VPC network in the SAME GCP project + region, peered to the hub
# network. NOT covered: cross-project or cross-GCP-region regions (bigger
# change — a second network peering/provider setup).
region_vpc_mode        = "shared"
region_vpc_cidr_public = "10.1.0.0/24" # used only when region_vpc_mode = dedicated

# dataserv fleet (arm64). 1 per zone for raft quorum.
dataserv_count         = 3
dataserv_machine_type  = "t2a-standard-8"

# METAENGINE_ARENA_SIZE unit string. ~5M files/GiB; prod is much larger.
arena_size = "1GB"

# Raft data disk (pd-ssd) at /mnt/raft. Ephemeral per instance; quorum re-syncs on replacement.
raft_disk_gb = 100

# Run gcserv co-located on each dataserv instance.
gcserv_colocated = true

# Region DB (mountos_data). RECOMMENDED: byo — bring a managed HA PostgreSQL
# (separate database from the hub admin DB; may be a different server/engine
# version). Set REGION_DB_URL in the `make region-bootstrap` environment; it is
# never a Terraform value. provision-sql is the eval/simple alternative (build
# REGION_DB_URL from region_db_host + region_db_password_secret — see the
# admin DB note above; same parity gap).
region_db_mode             = "byo"
region_db_tier             = "db-custom-2-8192" # provision-sql mode only
region_db_disk_gb          = 100                # provision-sql mode only
region_db_username         = "mountos"          # provision-sql mode only
region_db_provider_version = "POSTGRES_18"

# Region secret store; same model as the hub's. gcp (RECOMMENDED): hub and
# region share the project's mountos__* Secret Manager namespace, isolated by
# IAM (appserv can never read api-master; region services can never read the
# appserv secret). hashicorp: byo region Vault (never launched).
region_vault_provider = "gcp"
region_vault_addr     = "" # hashicorp only: https address
region_vault_ca_pem   = "" # hashicorp with a private CA only; empty = system CAs

# hashicorp only: dataserv AppRole for the byo region Vault, from the region seed step.
region_vault_role_id   = ""
region_vault_secret_id = ""

# ---------- blockserv (block data-plane) ----------

# Opt-in; only needed for local-block backends. Its Vault keys are already seeded
# by `make region-bootstrap` (unconditional); this only toggles running the fleet.
# Reuses the region Vault AppRole above (blockserv reads mountos/blockserv under
# the same mountos/data/* policy).
block_enable = false

# Active-active members of one block storage (up to 3, distinct zones). Each
# block_volume_id is a block volume UUID from provisioning a block storage on the
# hub via the Admin SDK; zone_index selects which zone the member lands in.
block_members = [
  # { block_volume_id = "00000000-0000-0000-0000-000000000000", zone_index = 0 },
  # { block_volume_id = "11111111-1111-1111-1111-111111111111", zone_index = 1 },
  # { block_volume_id = "22222222-2222-2222-2222-222222222222", zone_index = 2 },
]

# Network-optimized arm64 family and throughput-oriented cache disk per member.
block_machine_type = "t2a-standard-8"
block_cache_gb     = 500
