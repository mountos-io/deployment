# Copy to terraform.tfvars and fill in. Production placeholders below.

region = "eastus"
mode   = "production"

# Set when this subscription already hosts another mountOS deployment, so
# provisioned resource names and secret names don't collide. Must match the
# VAULT_RESOURCE_PREFIX env var used by every service in this deployment.
resource_prefix = ""

# SSH public key for operator break-glass access (Azure requires either an SSH
# key or password auth on every VM; not used by the boot/config flow itself).
admin_ssh_public_key = "" # REQUIRED — e.g. "ssh-ed25519 AAAA..."

# Public hub. Clients reach https://<hub_domain>; region services reach the
# internal LB directly (no DNS needed for SRPC).
hub_domain = "" # REQUIRED — your real public FQDN, e.g. hub.acme.com (placeholders are rejected)

# Existing Azure DNS zone for hub_domain. Empty skips DNS.
dns_zone_name           = ""
dns_zone_resource_group = "" # required when dns_zone_name is set

# Existing Key Vault certificate secret id for the App Gateway HTTPS listener.
# REQUIRED — Azure has no zero-touch DNS-validated managed-cert primitive like
# AWS ACM or Google-managed certs; bring your own (issue via Key Vault's
# integrated CA, Let's Encrypt, or import an existing PFX).
hub_certificate_secret_id = ""

# CIDR allowed to reach client-facing ports. Required; scope to your network — do not use 0.0.0.0/0 in production.
client_cidr = "203.0.113.0/24" # REPLACE with your operator/client CIDR

# appserv fleet (arm64, Dpsv5).
appserv_count    = 2
appserv_vm_size  = "Standard_D2ps_v5"

# Admin DB (PostgreSQL dialect). RECOMMENDED: byo — bring a managed HA
# PostgreSQL you already operate; this package then provisions no DB and never
# holds your DSN (set ADMIN_DB_URL in answers.env for `make bootstrap`; it is
# not a Terraform variable, so it never lands in tfstate). provision-pg is the
# eval/simple alternative: a ZoneRedundant Postgres Flexible Server whose
# generated password IS a Terraform value (rds.tf's PARITY GAP note) and is
# stored in Key Vault — build the DSN from `terraform output admin_db_host` +
# the admin_db_secret_id Key Vault secret.
admin_db_mode             = "byo"
admin_db_provider_version = "18" # PostgreSQL major version (byo: your server's)

# provision-pg mode only:
db_sku        = "GP_Standard_D2s_v3"
db_storage_gb = 128 # GiB, must map to a Flexible Server storage tier (32, 64, 128, ...)
db_username   = "mountos"

# Secret store. This package NEVER installs or launches HashiCorp Vault.
#   azure (RECOMMENDED)  cloud-native Key Vault: platform-managed HA,
#                        managed-identity auth, `make bootstrap` seeds mountos--*.
#   hashicorp            byo Vault (HCP Vault Dedicated or your own cluster):
#                        set vault_addr; `make bootstrap` seeds it via the API.
vault_provider = "azure"
vault_addr     = "" # hashicorp only: https address of your byo Vault
# hashicorp with a PRIVATE CA only: its CA PEM (published to the hub Key Vault
# for instance trust). Leave empty for a publicly-trusted certificate (HCP) —
# system CAs.
vault_ca_pem = ""

# hashicorp only: appserv AppRole from `make bootstrap`. secret_id is
# short-TTL; prefer Key Vault/wrapped delivery.
vault_role_id   = ""
vault_secret_id = ""

# mountOS package version. Empty installs latest.
mos_version = ""

# sha256 of the https://n.sh installer script; when set, cloud-init verifies
# the download before executing it. Strongly recommended for production.
mos_installer_sha256 = ""

# Email for Azure Monitor alert notifications (action group). Empty disables it.
alarm_email = ""

# ---------- region (dataserv + co-located gcserv) ----------

# Cluster UUID this region belongs to. Comes from the HUB provision step
# (created via the Admin SDK after the hub is up). Not created here.
region_cluster_id = "00000000-0000-0000-0000-000000000000"

# VNet placement for region resources. shared (default): region lives in the
# hub's VNet — simplest, no extra networking. dedicated: the region gets its
# own VNet in the SAME subscription/resource group + Azure region, peered to
# the hub VNet. NOT covered: cross-subscription or cross-Azure-region regions
# (bigger change — a second VNet peering/provider setup).
region_vpc_mode          = "shared"
region_vnet_cidr         = "10.1.0.0/16"
region_vnet_cidr_public  = "10.1.0.0/24"  # used only when region_vpc_mode = dedicated
region_vnet_cidr_private = "10.1.10.0/24" # used only when region_vpc_mode = dedicated

# dataserv fleet (arm64). 1 per zone for raft quorum.
dataserv_count   = 3
dataserv_vm_size = "Standard_D8ps_v5"

# METAENGINE_ARENA_SIZE unit string. ~5M files/GiB; prod is much larger.
arena_size = "1GB"

# Raft data disk (Premium_LRS) at /mnt/raft. Ephemeral per instance; quorum re-syncs on replacement.
raft_disk_gb = 100

# Run gcserv co-located on each dataserv instance.
gcserv_colocated = true

# Region DB (mountos_data). RECOMMENDED: byo — bring a managed HA PostgreSQL
# (separate database from the hub admin DB; may be a different server/engine
# version). Set REGION_DB_URL in the `make region-bootstrap` environment; it is
# never a Terraform value. provision-pg is the eval/simple alternative — same
# password parity gap as the admin DB note above (region_db_host +
# region_db_secret_id outputs give the DSN parts).
region_db_mode             = "byo"
region_db_sku              = "GP_Standard_D2s_v3" # provision-pg mode only
region_db_storage_gb       = 128                  # GiB, provision-pg mode only
region_db_username         = "mountos"            # provision-pg mode only
region_db_provider_version = "18"

# Region secret store; same model as the hub's. azure (RECOMMENDED): region
# services read/write the REGION Key Vault directly with their managed
# identities (appserv can never read api-master — it only has grants on the
# hub Key Vault; region services can never read the appserv secret; the DB
# password secrets live in the hub Key Vault, out of every service's reach).
# hashicorp: byo region Vault (never launched).
region_vault_provider = "azure"
region_vault_addr     = "" # hashicorp only: https address
region_vault_ca_pem   = "" # hashicorp with a private CA only; empty = system CAs

# hashicorp only: dataserv AppRole for the byo region Vault, from the region seed step.
region_vault_role_id   = ""
region_vault_secret_id = ""

# ---------- blockserv (block data-plane) ----------

# Opt-in; only needed for local-block backends. Its Vault keys are already seeded
# by `make region-bootstrap` (unconditional); this only toggles running the fleet.
# Reuses the region Vault AppRole above (blockserv reads mountos/blockserv under
# the same mountos/data/* policy).
block_enable = false

# Active-active members of one block storage (up to 3, distinct zones). Each
# block_volume_id is a block volume UUID from provisioning a block storage on the
# hub via the Admin SDK; zone_index selects which zone the member lands in.
block_members = [
  # { block_volume_id = "00000000-0000-0000-0000-000000000000", zone_index = 0 },
  # { block_volume_id = "11111111-1111-1111-1111-111111111111", zone_index = 1 },
  # { block_volume_id = "22222222-2222-2222-2222-222222222222", zone_index = 2 },
]

# Network-optimized arm64 family and throughput-oriented cache disk per member.
block_vm_size  = "Standard_D8ps_v5"
block_cache_gb = 500
